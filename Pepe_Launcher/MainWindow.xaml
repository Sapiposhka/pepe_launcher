<Window x:Class="Pepe_Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Pepe Launcher" Height="540" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#111827">
    <DockPanel Margin="10">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <Button x:Name="CheckUpdatesButton"
                    Content="Проверить обновления"
                    DockPanel.Dock="Right"
                    Padding="10,5"
                    Click="CheckUpdatesButton_Click"/>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Pepe Launcher"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <CheckBox x:Name="OnlyInstalledCheckBox"
                          Content="Показывать только установленные"
                          Margin="30,0,0,0"
                          VerticalAlignment="Center"
                          Foreground="White"
                          Checked="FilterChanged"
                          Unchecked="FilterChanged"/>
            </StackPanel>
        </DockPanel>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Список игр -->
            <Border Grid.Column="0" Margin="0,0,10,0" CornerRadius="8" Background="#1F2933">
                <DockPanel>
                    <Border DockPanel.Dock="Bottom"
                            Background="#111827"
                            CornerRadius="0,0,8,8"
                            Padding="10"
                            Visibility="{Binding ElementName=DownloadProgressBar, Path=Visibility}">
                        <StackPanel>
                            <TextBlock x:Name="DownloadStatusText"
                                       Text="Скачивание..."
                                       Foreground="White"
                                       Margin="0,0,0,6"/>
                            <ProgressBar x:Name="DownloadProgressBar"
                                         Minimum="0" Maximum="100"
                                         Height="10"
                                         Value="0"
                                         Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <ListView x:Name="GamesListView"
                              Background="Transparent"
                              BorderThickness="0"
                              Foreground="White"
                              SelectionChanged="GamesListView_SelectionChanged">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="Padding" Value="6"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Игра" DisplayMemberBinding="{Binding Name}" Width="180"/>
                                <GridViewColumn Header="Статус" Width="110">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding IsInstalled, Converter={StaticResource BoolToStatusConverter}}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Действие" Width="190">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="{Binding IsInstalled, Converter={StaticResource BoolToActionConverter}}"
                                                        Click="GameActionButton_Click"
                                                        Tag="{Binding}"
                                                        Padding="6,2"
                                                        Margin="0,0,6,0"/>
                                                <Button Content="Удалить"
                                                        Click="DeleteGameButton_Click"
                                                        Tag="{Binding}"
                                                        Padding="6,2"
                                                        Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </Border>

            <!-- Превью игры -->
            <Border Grid.Column="1" CornerRadius="8" Background="#1F2933" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Vertical" Margin="0,0,0,10">
                        <TextBlock x:Name="SelectedGameNameText"
                                   Text="Выберите игру"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="Bold"/>
                    </StackPanel>
                    <Border Grid.Row="1"
                            Background="#111827"
                            CornerRadius="6"
                            Padding="4">
                        <Image x:Name="SelectedGameImage"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
