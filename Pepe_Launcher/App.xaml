<Application x:Class="Pepe_Launcher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Pepe_Launcher"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <local:BoolToStatusConverter x:Key="BoolToStatusConverter"/>
        <local:BoolToActionConverter x:Key="BoolToActionConverter"/>

        <!-- Pepe / тёмная тема -->
        <Color x:Key="PepeAccentColor">#22c55e</Color>
        <Color x:Key="PepeAccentDarkColor">#16a34a</Color>
        <SolidColorBrush x:Key="PepeAccentBrush" Color="{StaticResource PepeAccentColor}"/>
        <SolidColorBrush x:Key="PepeAccentDarkBrush" Color="{StaticResource PepeAccentDarkColor}"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#1e293b"/>
        <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="#334155"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#94a3b8"/>
        <SolidColorBrush x:Key="DangerMutedBrush" Color="#dc2626"/>
        <SolidColorBrush x:Key="DangerMutedHoverBrush" Color="#ef4444"/>

        <!-- Заголовки: одна сплошная полоса, тонкие разделители, без «динамичных» вкладок и зазоров -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="#94a3b8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderBrush" Value="#273549"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border x:Name="HeaderBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="14,9,8,9"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="#151f33"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="#182236"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Вертикальная полоса прокрутки -->
        <ControlTemplate x:Key="VerticalScrollBarTemplate" TargetType="ScrollBar">
            <Border x:Name="TrackHost"
                    Width="12"
                    Background="#0f172a"
                    CornerRadius="0,10,10,0"
                    Padding="2,4"
                    SnapsToDevicePixels="True">
                <Track x:Name="PART_Track" IsDirectionReversed="True" Focusable="False">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.LineUpCommand" Opacity="0" Focusable="False" Height="0"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb x:Name="Thumb">
                            <Thumb.Template>
                                <ControlTemplate TargetType="Thumb">
                                    <Border x:Name="ThumbBd"
                                            MinHeight="28"
                                            Margin="1,0"
                                            Background="#475569"
                                            CornerRadius="4"
                                            SnapsToDevicePixels="True"/>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ThumbBd" Property="Background" Value="#22c55e"/>
                                        </Trigger>
                                        <Trigger Property="IsDragging" Value="True">
                                            <Setter TargetName="ThumbBd" Property="Background" Value="#16a34a"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Thumb.Template>
                        </Thumb>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.LineDownCommand" Opacity="0" Focusable="False" Height="0"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Border>
        </ControlTemplate>

        <!-- Горизонтальная полоса прокрутки -->
        <ControlTemplate x:Key="HorizontalScrollBarTemplate" TargetType="ScrollBar">
            <Border Height="12"
                    Background="#0f172a"
                    CornerRadius="0,0,10,10"
                    Padding="4,2"
                    SnapsToDevicePixels="True">
                <Track x:Name="PART_Track" IsDirectionReversed="False" Focusable="False">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.LineLeftCommand" Opacity="0" Focusable="False" Width="0"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb>
                            <Thumb.Template>
                                <ControlTemplate TargetType="Thumb">
                                    <Border x:Name="ThumbBdH"
                                            MinWidth="28"
                                            Margin="0,1"
                                            Background="#475569"
                                            CornerRadius="4"
                                            SnapsToDevicePixels="True"/>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ThumbBdH" Property="Background" Value="#22c55e"/>
                                        </Trigger>
                                        <Trigger Property="IsDragging" Value="True">
                                            <Setter TargetName="ThumbBdH" Property="Background" Value="#16a34a"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Thumb.Template>
                        </Thumb>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.LineRightCommand" Opacity="0" Focusable="False" Width="0"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Border>
        </ControlTemplate>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Stylus.IsPressAndHoldEnabled" Value="False"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="12"/>
                    <Setter Property="MinWidth" Value="12"/>
                    <Setter Property="Template" Value="{StaticResource VerticalScrollBarTemplate}"/>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="12"/>
                    <Setter Property="MinHeight" Value="12"/>
                    <Setter Property="Template" Value="{StaticResource HorizontalScrollBarTemplate}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PepeAccentButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PepeAccentBrush}"/>
            <Setter Property="Foreground" Value="#0f172a"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource PepeAccentDarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PepeOutlineButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource PepeAccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PepeAccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#14221a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PepeGameButton" TargetType="Button" BasedOn="{StaticResource PepeAccentButton}">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="PepeDangerButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource DangerMutedBrush}"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource DangerMutedHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#b91c1c"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Foreground" Value="{StaticResource PepeAccentBrush}"/>
            <Setter Property="Background" Value="#334155"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="8"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Application.Resources>
</Application>
